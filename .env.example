# Aplicación
APP_NAME=rxnTiendasIA
# En produccion: APP_ENV=production | APP_DEBUG=false | APP_SESSION_SECURE=true
APP_ENV=development
APP_DEBUG=true
APP_SESSION_SECURE=false
# APP_URL es referencia informativa. Las rutas de la app son absolutas desde /
# y NO dependen de esta variable en runtime. Se usa solo para documentacion.
# En produccion: APP_URL=https://suite.reaxionsoluciones.com.ar
APP_URL=http://localhost

# Base de datos
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# Correo (Opcional para produccion — si se usa funcionalidad de mail)
MAIL_HOST=
MAIL_PORT=465
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="RXN Tiendas"
