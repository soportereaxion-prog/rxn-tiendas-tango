Options -Indexes

# MIME types para PWA. Sin estos, Chrome puede rechazar el manifest o no
# considerar la app como instalable. webmanifest debe ir como
# application/manifest+json (estándar W3C).
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
    AddType application/x-web-app-manifest+json .webapp
</IfModule>

# Estrategia de deploy: Document Root apunta a public/
# El dominio resuelve rutas directamente desde aqui.
# NO usar RewriteBase con subpath. BASE = /

RewriteEngine On
RewriteBase /

# Servir archivos y directorios reales tal cual (css, js, uploads, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Todo lo demas va al front controller
RewriteRule ^ index.php [QSA,L]
